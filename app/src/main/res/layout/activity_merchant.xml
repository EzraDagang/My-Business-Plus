<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#113285">

    <ScrollView
        android:id="@+id/main_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_merchanticon"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Business+"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dashboard"
                            android:textColor="#113285"
                            android:textStyle="bold"
                            android:textSize="18sp" />
                        <Spinner
                            android:id="@+id/spinnerTimeframe"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TODAY'S NET RESULT"
                        android:textColor="#113285"
                        android:layout_marginTop="20dp"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black"/>

                    <TextView
                        android:id="@+id/tvNetRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+RM 367.67"
                        android:textSize="42sp"
                        android:textColor="#FF5722"
                        android:fontFamily="sans-serif-black"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="15dp"
                        android:layout_marginBottom="15dp">

                        <Button
                            android:id="@+id/btnProfitToggle"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:text="PROFIT"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="5dp"
                            app:cornerRadius="25dp" />

                        <Button
                            android:id="@+id/btnLossToggle"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:text="LOSS"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginStart="5dp"
                            app:cornerRadius="25dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="#F5F6F8"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginBottom="15dp">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_menu_sort_by_size"
                            app:tint="#A0A0A0"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weekly Sales Graph goes here"
                            android:textColor="#A0A0A0"
                            android:textSize="12sp"
                            android:layout_marginTop="5dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/insight_border"
                        android:padding="15dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Insights"
                            android:textColor="#113285"
                            android:textStyle="bold"
                            android:layout_marginBottom="5dp"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Insight: Prepare 85 karipap tomorrow (optimized from 100 based on sales data)\nAction: 20 karipap left. Launch a '3 for RM4' promo now to reduce unsold items."
                            android:textSize="12sp"
                            android:textColor="#333333" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="25dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="20dp"
                    android:paddingHorizontal="10dp"
                    android:gravity="center">

                    <LinearLayout android:id="@+id/nav_inventory" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_inventory" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inventory" android:textSize="10sp" android:textColor="#333333" android:layout_marginTop="5dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_qr" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="QR" android:textSize="10sp" android:textColor="#333333" android:layout_marginTop="5dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/nav_insights"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_insights" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Insights"
                            android:textSize="10sp"
                            android:layout_marginTop="5dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/nav_history" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_history_scroll" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History" android:textSize="10sp" android:textColor="#333333" android:layout_marginTop="5dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/inventoryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

</RelativeLayout>