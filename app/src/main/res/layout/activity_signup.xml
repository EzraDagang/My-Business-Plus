<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tng_bg_blue"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/tng_card_dark"
        app:cardCornerRadius="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Register Merchant"
                android:textColor="@color/tng_text_white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <EditText
                android:id="@+id/etDisplayName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Merchant Name"
                android:textColorHint="#999"
                android:textColor="@color/tng_text_white"
                android:backgroundTint="@color/tng_yellow"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Email"
                android:textColorHint="#999"
                android:textColor="@color/tng_text_white"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/tng_yellow"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Password"
                android:textColorHint="#999"
                android:textColor="@color/tng_text_white"
                android:inputType="textPassword"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/tng_yellow"/>

            <Button
                android:id="@+id/btnSignUp"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="CREATE ACCOUNT"
                android:textColor="@color/tng_text_dark"
                android:backgroundTint="@color/tng_yellow"
                android:layout_marginTop="32dp"
                app:cornerRadius="28dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>